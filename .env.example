# Copy to .env and adjust. Used by docker-compose.yml for local parity.

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1
DB_NAME=vapeshop_db

# API
PORT=3001
NODE_ENV=production

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:3001

# Admin
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
DB_CONNECTION=pgsql
